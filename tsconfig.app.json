{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "types": ["vite/client", "vitest/globals"],
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "app/*": ["src/app/*"],
      "domain/*": ["src/domain/*"],
      "features/*": ["src/features/*"],
      "ui/*": ["src/ui/*"],
      "styles/*": ["src/styles/*"],
      "shared/*": ["src/shared/*"],
      "components/*": ["src/ui/components/*"],
      "layouts/*": ["src/ui/layouts/*"],
      "theme/*": ["src/ui/theme/*"],
      "selectors/*": ["src/domain/state/selectors/*"],
      "reducers/*": ["src/domain/state/reducers/*"],
      "synth/*": ["src/domain/audio/synth/*"],
      "utils/*": ["src/shared/utils/*"],
      "globalStyles/*": ["src/styles/*"],
      "store": ["src/app/store/index.ts"],
      "actionCreators": ["src/domain/state/actionCreators.ts"],
      "actionTypes": ["src/domain/state/actionTypes.ts"],
      "store-constants": ["src/domain/state/store-constants.ts"],
      "initialState": ["src/domain/state/initialState.ts"],
      "helpers": ["src/domain/helpers.ts"],
      "audioCtxContext": ["src/app/providers/audioCtxContext.tsx"]
    }
  },
  "include": ["src"]
}
